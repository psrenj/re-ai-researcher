# Required shared API key for backend + web server calls
API_KEY=change-me

# OpenAI runtime key used by API research pipeline
OPENAI_API_KEY=sk-...

# API server config
PORT=8787
DATABASE_PATH=./data/research.sqlite
XANO_ENDPOINT=xano_endpoint

# OpenAI model config
OPENAI_MODEL_DISCOVERY=gpt-5-mini
OPENAI_MODEL_EXTRACTION=gpt-5-mini
OPENAI_PROMPT_ID_CASINO_DISCOVERY=
OPENAI_PROMPT_VERSION_CASINO_DISCOVERY=
OPENAI_PROMPT_ID_CASINO_OFFERS_DISCOVERY=
OPENAI_PROMPT_VERSION_CASINO_OFFERS_DISCOVERY=
OPENAI_PROMPT_ID_DISCOVERY=
OPENAI_PROMPT_VERSION_DISCOVERY=
OPENAI_PROMPT_ID_OFFERS=
OPENAI_PROMPT_VERSION_OFFERS=
OPENAI_MAX_OUTPUT_TOKENS_DISCOVERY=2600
OPENAI_MAX_OUTPUT_TOKENS_OFFERS=2400
OPENAI_CONCURRENCY=5
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_MS=800

# Run budget and limits
MAX_CASINOS_PER_RUN=20
MAX_STATES_PER_RUN=4
CONFIDENCE_THRESHOLD=0.65
RUN_TOKEN_CAP=200000

# Web app -> API target
API_BASE_URL=http://localhost:8787
